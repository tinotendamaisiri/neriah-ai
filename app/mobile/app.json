{
  "expo": {
    "name": "Neriah",
    "slug": "neriah",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#ffffff"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D7377"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.neriah.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Neriah needs camera access to photograph student exercise books.",
        "NSPhotoLibraryUsageDescription": "Neriah needs photo library access to select book images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D7377"
      },
      "softwareKeyboardLayoutMode": "resize",
      "package": "app.neriah.mobile",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://us-central1-neriah-ai-492302.cloudfunctions.net/neriah-grading/api"
    },
    "plugins": [
      "expo-mail-composer",
      "expo-secure-store",
      "expo-localization",
      "@react-native-community/datetimepicker"
    ]
  }
}
