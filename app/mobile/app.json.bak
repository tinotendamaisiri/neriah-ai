{
  "expo": {
    "name": "Neriah",
    "slug": "neriah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D7377"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.neriah.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Neriah needs camera access to photograph student exercise books.",
        "NSPhotoLibraryUsageDescription": "Neriah needs photo library access to select book images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D7377"
      },
      "package": "app.neriah.mobile",
      "versionCode": 3,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://us-central1-neriah-ai-492302.cloudfunctions.net/neriah-grading/api",
      "eas": {
        "projectId": "f39a6b2a-8bab-4d20-843a-afd459cf1caf"
      }
    },
    "plugins": [
      "expo-mail-composer",
      "expo-secure-store",
      "expo-localization",
      "@react-native-community/datetimepicker"
    ]
  }
}
