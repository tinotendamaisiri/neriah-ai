# ─────────────────────────────────────────────────────────
# NERIAH AFRICA — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────

# ── SANITY (Blog CMS) ─────────────────────────────────────
# Get from sanity.io/manage → your project → API → Tokens
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token_here
SANITY_REVALIDATE_SECRET=generate_a_random_32_char_string_here

# ── SUPABASE (Database for forms and leads) ───────────────
# Get from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT: Use SERVICE_ROLE key for server-side only. Never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── RESEND (Email delivery) ───────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM=Neriah Africa <no-reply@send.neriah.africa>
RESEND_NOTIFY_EMAIL=tino@neriah.africa,ops@neriah.africa

# ── NEXTAUTH (Studio authentication) ─────────────────────
# Get from console.cloud.google.com → OAuth 2.0 credentials
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_32_char_secret_here
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Comma-separated emails allowed to access /studio
ALLOWED_STUDIO_EMAILS=tino@neriah.africa,ops@neriah.africa

# ── UPSTASH REDIS (Rate limiting on forms) ───────────────
# Get from upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── SITE CONFIG ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://neriah.africa
