# .gcloudignore — controls what gcloud uploads when deploying Cloud Functions.
# Only main.py, requirements.txt, shared/, functions/, and root-level .py files
# are needed. Everything else is excluded.

# Mobile app
app/

# Website
neriah-website/

# Assets / media
assets/
*.png
*.jpg
*.jpeg
*.mp4
*.task
*.litertlm

# Notebooks / data science
samples/
notebooks/
kaggle_notebook.ipynb

# Git
.git/
.gitignore

# Node
node_modules/

# Mobile build artifacts
ios/
android/
.expo/
build/
.gradle/
*.apk
*.ipa

# Python artifacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# IDE / editor
.vscode/
.idea/

# Old Azure Functions backend (not used by GCP deployment)
backend/

# Secrets / credentials
credentials.json
.env
.env.*
*.key
*.pem

# Misc
scripts/
infra/
docs/
README.md
CLAUDE.md
