# Neriah Backend — environment variables template
# Copy to .env and fill in real values. Never commit .env.

# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
AZURE_COSMOS_KEY=<key>

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=<storage-account-name>
AZURE_STORAGE_KEY=<key>
AZURE_STORAGE_CONTAINER_SCANS=scans
AZURE_STORAGE_CONTAINER_MARKED=marked
AZURE_STORAGE_CONTAINER_SUBMISSIONS=submissions

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<account>.openai.azure.com/
AZURE_OPENAI_KEY=<key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o

# Azure AI Document Intelligence
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<account>.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=<key>

# WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=<your-verify-token>
WHATSAPP_ACCESS_TOKEN=<permanent-access-token>
WHATSAPP_PHONE_NUMBER_ID=<phone-number-id>

# EcoCash (not active in MVP)
ECOCASH_API_KEY=
ECOCASH_MERCHANT_ID=

# App JWT auth
APP_JWT_SECRET=<random-secret-min-32-chars>

# Azure Communication Services (email)
AZURE_COMMUNICATION_CONNECTION_STRING=<connection-string>
NERIAH_EMAIL_FROM_ADDRESS=mark@neriah.africa

# Function App (used to build approval links in lecturer emails)
FUNCTION_APP_URL=https://neriah-func-dev.azurewebsites.net
# Azure Function App default host key — get from Azure Portal:
# Functions → App keys → default
FUNCTION_APP_KEY=<host-key>

# Runtime
ENVIRONMENT=dev
