# Neriah — Environment Variables
# Copy this file to .env (local) or set these in Azure Functions Application Settings (deployed).
# Never commit real credentials. See CLAUDE.md Section 8 for descriptions.

# ── Azure Cosmos DB ──────────────────────────────────────────────────────────
AZURE_COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
AZURE_COSMOS_KEY=<your-cosmos-primary-key>

# ── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT=<your-storage-account-name>
AZURE_STORAGE_KEY=<your-storage-account-key>
AZURE_STORAGE_CONTAINER_SCANS=scans          # raw uploaded photos
AZURE_STORAGE_CONTAINER_MARKED=marked        # annotated output images

# ── Azure OpenAI Service ─────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini          # deployment name in Azure OpenAI Studio

# ── Azure AI Document Intelligence ──────────────────────────────────────────
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=<your-di-key>

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=<random-string-you-set-in-meta-developer-console>
WHATSAPP_ACCESS_TOKEN=<permanent-graph-api-access-token>
WHATSAPP_PHONE_NUMBER_ID=<whatsapp-business-phone-number-id>

# ── EcoCash Payments (MVP: out of scope, set to placeholder) ─────────────────
ECOCASH_API_KEY=<ecocash-api-key>
ECOCASH_MERCHANT_ID=<ecocash-merchant-id>

# ── App Auth ─────────────────────────────────────────────────────────────────
APP_JWT_SECRET=<long-random-secret-for-hs256-jwt-signing>

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=dev                              # dev | prod — controls logging verbosity
