# Neriah GCP — Environment Variables
# Copy to .env for local dev. Set these in Cloud Run / Cloud Functions environment for deployed envs.
# Never commit real credentials.

# ── GCP Core ─────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=neriah-ai-492302
GCP_REGION=us-central1

# ── Firestore ─────────────────────────────────────────────────────────────────
FIRESTORE_DATABASE=(default)

# ── Cloud Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET_SCANS=neriah-scans-dev          # raw uploaded photos
GCS_BUCKET_MARKED=neriah-marked-dev        # annotated output images
GCS_BUCKET_SUBMISSIONS=neriah-submissions-dev  # tertiary PDF/DOCX uploads

# ── Inference backend ─────────────────────────────────────────────────────────
INFERENCE_BACKEND=ollama          # ollama | vertex

# ── Ollama (local inference) ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_STUDENT=gemma4:e2b                  # simple / student queries
OLLAMA_MODEL_TEACHER=gemma4:latest               # teacher grading / complex tasks
OLLAMA_MODEL_CLOUD=gemma4:26b-a4b-it-q4_K_M     # cloud-equivalent quantised model

# ── Vertex AI / Gemma 4 (cloud inference) ────────────────────────────────────
# Required only when INFERENCE_BACKEND=vertex
VERTEX_MODEL_ID=gemma-4-26b-a4b-it
VERTEX_ENDPOINT_ID=                # projects/.../locations/.../endpoints/{id}
# On-device model variants (reference only — not used by this service):
#   gemma-4-e4b-it   teacher device
#   gemma-4-e2b-it   student device
VERTEX_TEMPERATURE=0.1
VERTEX_MAX_OUTPUT_TOKENS=4096

# ── Document AI (OCR — tertiary PDF/DOCX only) ────────────────────────────────
# Create a processor of type DOCUMENT_OCR in Cloud Console > Document AI
DOCAI_PROCESSOR_ID=your-processor-id
DOCAI_PROCESSOR_LOCATION=us

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=random-string-set-in-meta-developer-console
WHATSAPP_ACCESS_TOKEN=permanent-graph-api-access-token
WHATSAPP_PHONE_NUMBER_ID=whatsapp-business-phone-number-id

# ── App Auth ──────────────────────────────────────────────────────────────────
APP_JWT_SECRET=long-random-secret-for-hs256-jwt-signing

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=dev    # dev | prod — controls logging verbosity
